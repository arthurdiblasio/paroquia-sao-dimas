generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  COMUNICACAO
}

enum AppointmentType {
  BATISMO
  CASAMENTO
}

enum AppointmentStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
}

enum FinancialReportStatus {
  STARTED
  IN_PROGRESS
  FINISHED
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  news             News[]
  financialReports FinancialReport[]
  homilies         Homily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// NEWS
//////////////////////////////////////////////////////

model NewsCategory {
  id   String @id @default(uuid())
  name String
  slug String @unique

  news News[]

  createdAt DateTime @default(now())
}

model News {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  slug        String    @unique
  content     String
  imageUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?

  categoryId String
  category   NewsCategory @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  media NewsMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// CHURCHES
//////////////////////////////////////////////////////

model Church {
  id           String  @id @default(uuid())
  name         String
  address      String
  description  String?
  latitude     Float
  longitude    Float
  isMainChurch Boolean @default(false)

  massSchedules MassSchedule[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  crunchMedias CrunchMedia[]
}

model MassSchedule {
  id       String @id @default(uuid())
  churchId String
  church   Church @relation(fields: [churchId], references: [id])

  dayOfWeek Int
  time      String
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParishPriest {
  id        String    @id @default(uuid())
  name      String
  birthDate DateTime
  birthCity String
  photoUrl  String?
  startDate DateTime
  endDate   DateTime?
  deathDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// MINISTRIES (PASTORAIS)
//////////////////////////////////////////////////////

model Ministry {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  description  String?
  imageUrl     String?
  contactName  String?
  contactPhone String?

  media MinistryMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// FINANCIAL REPORTS
//////////////////////////////////////////////////////

model FinancialReport {
  id                 String                @id @default(uuid())
  title              String
  description        String
  status             FinancialReportStatus @default(STARTED)
  progressPercentage Int                   @default(0)

  published   Boolean   @default(false)
  publishedAt DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  phases FinancialReportPhase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialReportPhase {
  id          String          @id @default(uuid())
  reportId    String
  report      FinancialReport @relation(fields: [reportId], references: [id])
  title       String
  phaseOrder  Int
  doneDetails String?
  nextDetails String?

  media FinancialReportPhaseMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, phaseOrder])
}

//////////////////////////////////////////////////////
// HOMILIES
//////////////////////////////////////////////////////

model Homily {
  id          String   @id @default(uuid())
  title       String
  description String?
  content     String?
  videoUrl    String?
  date        DateTime

  published   Boolean   @default(false)
  publishedAt DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  media HomilyMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// APPOINTMENTS
//////////////////////////////////////////////////////

model Appointment {
  id            String          @id @default(uuid())
  type          AppointmentType
  name          String
  phone         String
  email         String
  preferredDate DateTime?
  notes         String?
  details       Json?

  status AppointmentStatus @default(PENDING)

  documents AppointmentDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentDocument {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  mediaId       String
  media         Media       @relation(fields: [mediaId], references: [id])
  documentKey   String?
  documentLabel String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// MEDIA LIBRARY
//////////////////////////////////////////////////////

model Media {
  id      String    @id @default(uuid())
  url     String
  type    MediaType
  altText String?
  size    Int?

  createdAt DateTime @default(now())

  news                  NewsMedia[]
  ministries            MinistryMedia[]
  financialReportPhases FinancialReportPhaseMedia[]
  homilies              HomilyMedia[]
  crunchMedias          CrunchMedia[]
  appointments          AppointmentDocument[]
}

//////////////////////////////////////////////////////
// MEDIA RELATIONS
//////////////////////////////////////////////////////

model NewsMedia {
  newsId  String
  mediaId String

  news  News  @relation(fields: [newsId], references: [id])
  media Media @relation(fields: [mediaId], references: [id])

  @@id([newsId, mediaId])
}

model MinistryMedia {
  ministryId String
  mediaId    String

  ministry Ministry @relation(fields: [ministryId], references: [id])
  media    Media    @relation(fields: [mediaId], references: [id])

  @@id([ministryId, mediaId])
}

model FinancialReportPhaseMedia {
  phaseId String
  mediaId String

  phase FinancialReportPhase @relation(fields: [phaseId], references: [id])
  media Media                @relation(fields: [mediaId], references: [id])

  @@id([phaseId, mediaId])
}

model HomilyMedia {
  homilyId String
  mediaId  String

  homily Homily @relation(fields: [homilyId], references: [id])
  media  Media  @relation(fields: [mediaId], references: [id])

  @@id([homilyId, mediaId])
}

model CrunchMedia {
  crunchId String
  mediaId  String

  crunch Church @relation(fields: [crunchId], references: [id])
  media  Media  @relation(fields: [mediaId], references: [id])

  @@id([crunchId, mediaId])
}
